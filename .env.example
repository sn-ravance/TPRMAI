# Database
DATABASE_URL="postgresql://tprm_user:your_password@localhost:5432/tprm_db"

# Authentication
NEXTAUTH_SECRET="generate-a-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider - Claude via Azure AI Foundry (PRIMARY)
# This application uses Claude models hosted on Azure AI Foundry as the primary AI provider.
# OpenAI is available as an optional alternative only.

# PRIMARY: Azure AI Foundry with Claude (REQUIRED)
AZURE_OPENAI_API_KEY="your-azure-ai-foundry-key"
AZURE_OPENAI_ENDPOINT="https://your-instance.openai.azure.com"
AZURE_OPENAI_INSTANCE_NAME="your-instance-name"
AZURE_OPENAI_DEPLOYMENT_NAME="claude-opus-4-6"
AZURE_OPENAI_FALLBACK_DEPLOYMENT_NAME="claude-opus-4-5"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# OPTIONAL: Direct OpenAI API (Alternative, not primary)
# Only use if Azure AI Foundry with Claude is unavailable
# OPENAI_API_KEY="sk-your-openai-key"

# External Security APIs (optional)
SECURITY_SCORECARD_API_KEY=""
BITSIGHT_API_KEY=""
DNB_API_KEY=""

# File Upload Settings
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="52428800"
